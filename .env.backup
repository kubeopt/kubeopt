# Azure Authentication
# Option 1: Service Principal (Recommended for production)
AZURE_CLIENT_ID=your-service-principal-app-id
AZURE_CLIENT_SECRET=your-service-principal-password
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# Option 2: Managed Identity (for AKS/Azure VMs)
# AZURE_CLIENT_ID=your-managed-identity-client-id
# AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=0
LOG_LEVEL=INFO

# Automatic Analysis Configuration
AUTO_ANALYSIS_ENABLED=true
AUTO_ANALYSIS_INTERVAL=1

# Database
DATABASE_PATH=/app/data/aks_optimizer.db

# Optional: Redis Cache
# REDIS_URL=redis://redis:6379/0

# Optional: Monitoring
# PROMETHEUS_PORT=9090