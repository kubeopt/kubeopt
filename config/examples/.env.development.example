# AKS Cost Optimizer - Development Environment Configuration
# Copy this file to .env.local for development setup
# Use dev-mode.py script for easier license management

# ===========================
# Development Mode Settings
# ===========================
# Flask Development Configuration
FLASK_ENV=development
FLASK_DEBUG=true
PRODUCTION_MODE=false

# Development License (Full Enterprise Access)
kubeopt_LICENSE_KEY=ENT-dev12345-NEVER
kubeopt_DEV_MODE=true

# Development-friendly settings
LOG_LEVEL=DEBUG
APP_URL=http://localhost:5001

# ===========================
# Azure Configuration (Required)
# ===========================
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ===========================
# Development Analysis Settings
# ===========================
# Enable auto-analysis for testing (careful - this runs in background)
AUTO_ANALYSIS_ENABLED=false

# Faster refresh intervals for development (in hours)
ANALYSIS_REFRESH_INTERVAL=1

# Lower cost thresholds for easier testing
COST_ALERT_THRESHOLD=100

# ===========================
# Development Email Testing (Optional)
# ===========================
# Use test email settings for development
EMAIL_ENABLED=false

# Development SMTP (use a test email service)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-test-email@gmail.com
SMTP_PASSWORD=your-app-password

# Development recipients
EMAIL_RECIPIENTS=your-dev-email@domain.com

# ===========================
# Development Slack Testing (Optional)
# ===========================
# Use a test Slack workspace for development
SLACK_ENABLED=false

# Test Slack webhook (create in test workspace)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/TEST/WEBHOOK

# Test channel
SLACK_CHANNEL=#dev-testing

# ===========================
# Development Features
# ===========================
# Enable all enterprise features for development
ENABLE_MULTI_SUBSCRIPTION=true
PARALLEL_PROCESSING=true
ML_TRAINING_ENABLED=true

# Development database paths (local)
DATABASE_PATH=./infrastructure/persistence/database/
ML_MODEL_PATH=./machine_learning/data/models/

# ===========================
# Development Security
# ===========================
# Use a simple secret for development (NEVER in production)
FLASK_SECRET_KEY=dev-secret-key-change-for-production

# Development cache settings
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# ===========================
# Azure SDK Development Settings
# ===========================
AZURE_CORE_COLLECT_TELEMETRY=false
AZURE_CONFIG_DIR=~/.azure

# Development Python path
PYTHONPATH=.

# ===========================
# Development Testing Settings
# ===========================
# Enable verbose logging for all components
LOG_LEVEL=DEBUG

# Test mode flags (for feature testing)
TEST_MODE=true
MOCK_AZURE_RESPONSES=false

# Development port (if different from production)
DEV_PORT=5001

# ===========================
# Hot Reload & Development Tools
# ===========================
# Flask development server settings
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5001
FLASK_RUN_DEBUG=true

# Enable auto-restart on file changes
FLASK_ENV=development

# ===========================
# Development License Testing
# ===========================
# Test different license tiers (use dev-mode.py script instead)
# LICENSE_TIER=enterprise  # free, pro, enterprise

# Bypass license checks for testing (use carefully)
# kubeopt_BYPASS_LICENSE=false

# ===========================
# Development API Settings
# ===========================
# Enable CORS for frontend development
ENABLE_CORS=true

# API rate limiting (disabled for development)
API_RATE_LIMIT_ENABLED=false

# Enable detailed API error responses
API_DEBUG_RESPONSES=true

# ===========================
# Development UI Settings
# ===========================
# Enable UI development features
UI_DEBUG_MODE=true

# Show debug information in templates
TEMPLATE_DEBUG=true

# Enable CSS/JS hot reloading
ASSETS_DEBUG=true