# AKS Cost Optimizer - Production Environment Configuration
# Copy this file to .env and update with your actual values
# For development, use .env.development.example instead
# NEVER commit .env files with real credentials to git

# ===========================
# Azure Configuration (Required)
# ===========================
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-service-principal-client-id
AZURE_CLIENT_SECRET=your-service-principal-client-secret

# Optional: Specific subscription ID (if not set, will discover all accessible)
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ===========================
# Email Notifications (Optional)
# ===========================
# Enable email notifications for cost alerts
EMAIL_ENABLED=false

# SMTP Configuration
# For GoDaddy: smtpout.secureserver.net:587
# For Gmail: smtp.gmail.com:587 (requires app password)
# For Office 365: smtp-mail.outlook.com:587
SMTP_SERVER=smtpout.secureserver.net
SMTP_PORT=587
SMTP_USERNAME=alerts@your-domain.com
SMTP_PASSWORD=your-email-password

# Recipients (comma-separated)
EMAIL_RECIPIENTS=admin@your-domain.com,devops@your-domain.com

# ===========================
# Slack Notifications (Optional)
# ===========================
# Enable Slack notifications for cost alerts
SLACK_ENABLED=false

# Slack webhook URL (get from https://api.slack.com/apps)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Default channel for notifications (include the #)
SLACK_CHANNEL=#aks-cost-alerts

# ===========================
# Application Settings
# ===========================
# Base URL for dashboard links in notifications
APP_URL=http://localhost:5001

# Flask environment (development/production)
FLASK_ENV=production
PRODUCTION_MODE=true

# Security Settings
FLASK_SECRET_KEY=your-super-secret-key-change-this

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ===========================
# Feature Configuration
# ===========================
# Enable multi-subscription support
ENABLE_MULTI_SUBSCRIPTION=true

# Enable parallel processing
PARALLEL_PROCESSING=true

# Auto-analysis scheduling
AUTO_ANALYSIS_ENABLED=false
ANALYSIS_REFRESH_INTERVAL=24

# Cost alert threshold (USD)
COST_ALERT_THRESHOLD=1500

# License tier (free/pro/enterprise)
LICENSE_TIER=free

# ===========================
# Database Settings
# ===========================
# SQLite paths are relative to container
DATABASE_PATH=/app/infrastructure/persistence/database/

# ===========================
# Machine Learning Settings
# ===========================
ML_MODEL_PATH=/app/machine_learning/data/models/
ML_TRAINING_ENABLED=true

# ===========================
# Cache Settings
# ===========================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# ===========================
# Azure SDK Configuration
# ===========================
AZURE_CORE_COLLECT_TELEMETRY=false
AZURE_CONFIG_DIR=/home/appuser/.azure

# ===========================
# Container Configuration
# ===========================
# Container variant (bytecode, pyinstaller, obfuscated)
CONTAINER_VARIANT=pyinstaller

# Python path (for application)
PYTHONPATH=/app