# AKS Cost Optimizer Configuration - Example File
# Copy this to .env and update with your actual values

# Azure Configuration
# (Add your Azure settings here)

# Claude API Configuration
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model Selection - HAIKU RECOMMENDED FOR PRODUCTION 🎯
# PRODUCTION RECOMMENDED:
#   - claude-3-haiku-20240307 (BEST: $0.25 input/$1.25 output, 96% savings vs Sonnet)
# Cost-effective alternatives:
#   - claude-3-5-sonnet-20240620 ($3 input/$15 output per 1M tokens)
# Premium models (high cost):
#   - claude-sonnet-4-5-20250929 ($3 input/$15 output per 1M tokens)
#   - claude-opus-4-1-20250805 ($15 input/$75 output per 1M tokens)
CLAUDE_MODEL=claude-3-haiku-20240307

# Cost Optimization Settings - IMPORTANT FOR REDUCING API COSTS
# Max Output Tokens (REDUCED FOR COST SAVINGS)
# Claude 4.5 models support up to 16000, Claude 3.x models up to 8192
# 🔥 COST OPTIMIZATION: Reduced from 8000 to 3000 to save 62% on output costs
# This provides sufficient tokens for implementation plans while minimizing costs
CLAUDE_MAX_OUTPUT_TOKENS=4000  # Increased for comprehensive plans with real metadata

# Haiku Batched Generation (enabled by default)
# Uses 3 API calls to stay within Haiku's 4,096 token limit while delivering comprehensive plans
# Automatically enabled when using Haiku model - provides 96% cost savings with equal quality
CLAUDE_USE_SPLIT_MODE=false

# Max Retries (REDUCED TO SAVE MONEY ON FAILED REQUESTS)
# Reduce retries to save money on permanent failures (like 404 model not found)
CLAUDE_MAX_RETRIES=2           # Reduce retries to save money

# Cost Tracking
# Enable detailed cost tracking and logging
CLAUDE_ENABLE_COST_TRACKING=true

# Max Context Tokens (for input - context builder handles this)
CLAUDE_MAX_CONTEXT_TOKENS=180000

# Auto Analysis Settings
# Disable auto analysis for development/testing to prevent background processing
AUTO_ANALYSIS_ENABLED=false
AUTO_ANALYSIS_INTERVAL=240m

# Slack Integration
APP_URL=http://localhost:5001
SLACK_CHANNEL=your-channel
SLACK_COST_THRESHOLD=1500
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email Settings
EMAIL_ENABLED=true
EMAIL_RECIPIENTS=your-email@example.com
FROM_EMAIL=your-app@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_PORT=587
SMTP_SERVER=your-smtp-server
SMTP_USERNAME=your-smtp-username