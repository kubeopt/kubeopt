# AKS Cost Optimizer Configuration - Example File
# Copy this to .env and update with your actual values

# Azure Configuration
# (Add your Azure settings here)

# Claude API Configuration
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-5-sonnet-20241022
MAX_CONTEXT_TOKENS=45000

# Slack Integration
APP_URL=http://localhost:5001
SLACK_CHANNEL=your-channel
SLACK_COST_THRESHOLD=1500
SLACK_ENABLED=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email Settings
EMAIL_ENABLED=true
EMAIL_RECIPIENTS=your-email@example.com
FROM_EMAIL=your-app@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_PORT=587
SMTP_SERVER=your-smtp-server
SMTP_USERNAME=your-smtp-username