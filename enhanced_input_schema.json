{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KubeOpt Enhanced Input Schema",
  "description": "Enhanced schema for comprehensive AKS cost analysis including workload-level details",
  "type": "object",
  "required": ["cost_analysis", "cluster_info"],
  "properties": {
    "cost_analysis": {
      "description": "Existing cost breakdown structure - preserved as is",
      "type": "object",
      "properties": {
        "total_cost": { "type": "number", "minimum": 0 },
        "node_cost": { "type": "number", "minimum": 0 },
        "storage_cost": { "type": "number", "minimum": 0 },
        "networking_cost": { "type": "number", "minimum": 0 },
        "control_plane_cost": { "type": "number", "minimum": 0 },
        "registry_cost": { "type": "number", "minimum": 0 },
        "other_cost": { "type": "number", "minimum": 0 },
        "cost_period_days": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "default": "USD" }
      }
    },
    
    "cluster_info": {
      "description": "Basic cluster identification and metadata",
      "type": "object",
      "required": ["cluster_name", "resource_group", "subscription_id"],
      "properties": {
        "cluster_name": { "type": "string" },
        "resource_group": { "type": "string" },
        "subscription_id": { "type": "string" },
        "kubernetes_version": { "type": "string" },
        "location": { "type": "string" },
        "total_node_count": { "type": "integer", "minimum": 0 },
        "analysis_timestamp": { "type": "string", "format": "date-time" }
      }
    },

    "node_pools": {
      "description": "Detailed node pool configurations and utilization",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "vm_sku", "node_count"],
        "properties": {
          "name": { "type": "string" },
          "vm_sku": { "type": "string" },
          "node_count": { "type": "integer", "minimum": 0 },
          "min_count": { "type": "integer", "minimum": 0 },
          "max_count": { "type": "integer", "minimum": 0 },
          "cpu_cores_per_node": { "type": "number", "minimum": 0 },
          "memory_gb_per_node": { "type": "number", "minimum": 0 },
          "utilization": {
            "type": "object",
            "properties": {
              "cpu_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
              "memory_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
              "avg_cpu_last_7d": { "type": "number", "minimum": 0, "maximum": 100 },
              "avg_memory_last_7d": { "type": "number", "minimum": 0, "maximum": 100 },
              "peak_cpu_last_7d": { "type": "number", "minimum": 0, "maximum": 100 },
              "peak_memory_last_7d": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          },
          "monthly_cost": { "type": "number", "minimum": 0 },
          "workload_type": { 
            "type": "string", 
            "enum": ["system", "user", "mixed"],
            "default": "user"
          },
          "spot_enabled": { "type": "boolean", "default": false },
          "taints": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": { "type": "string" },
                "value": { "type": "string" },
                "effect": { "type": "string", "enum": ["NoSchedule", "PreferNoSchedule", "NoExecute"] }
              }
            }
          }
        }
      }
    },

    "workloads": {
      "description": "Detailed workload configurations and performance metrics",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["namespace", "name", "type"],
        "properties": {
          "namespace": { "type": "string" },
          "name": { "type": "string" },
          "type": { 
            "type": "string", 
            "enum": ["Deployment", "StatefulSet", "DaemonSet", "Job", "CronJob"]
          },
          "replicas": {
            "type": "object",
            "properties": {
              "desired": { "type": "integer", "minimum": 0 },
              "ready": { "type": "integer", "minimum": 0 },
              "available": { "type": "integer", "minimum": 0 }
            }
          },
          "has_hpa": { "type": "boolean", "default": false },
          "hpa_name": { "type": "string" },
          "resources": {
            "type": "object",
            "properties": {
              "requests": {
                "type": "object",
                "properties": {
                  "cpu": { "type": "string" },
                  "memory": { "type": "string" }
                }
              },
              "limits": {
                "type": "object", 
                "properties": {
                  "cpu": { "type": "string" },
                  "memory": { "type": "string" }
                }
              }
            }
          },
          "actual_usage": {
            "type": "object",
            "properties": {
              "cpu": {
                "type": "object",
                "properties": {
                  "avg_millicores": { "type": "number", "minimum": 0 },
                  "p95_millicores": { "type": "number", "minimum": 0 },
                  "avg_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                  "p95_percentage": { "type": "number", "minimum": 0, "maximum": 100 }
                }
              },
              "memory": {
                "type": "object",
                "properties": {
                  "avg_bytes": { "type": "number", "minimum": 0 },
                  "p95_bytes": { "type": "number", "minimum": 0 },
                  "avg_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                  "p95_percentage": { "type": "number", "minimum": 0, "maximum": 100 }
                }
              }
            }
          },
          "cost_estimate": {
            "type": "object",
            "properties": {
              "monthly_cost": { "type": "number", "minimum": 0 },
              "cpu_cost": { "type": "number", "minimum": 0 },
              "memory_cost": { "type": "number", "minimum": 0 },
              "storage_cost": { "type": "number", "minimum": 0 }
            }
          },
          "traffic_pattern": {
            "type": "object",
            "properties": {
              "pattern_type": { 
                "type": "string", 
                "enum": ["STEADY", "BURSTY", "PERIODIC", "LOW_UTILIZATION", "CPU_INTENSIVE", "MEMORY_INTENSIVE"],
                "default": "STEADY"
              },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "peak_hours": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0, "maximum": 23 }
              },
              "scaling_events_last_7d": { "type": "integer", "minimum": 0 }
            }
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "default": "medium"
          },
          "environment": {
            "type": "string",
            "enum": ["production", "staging", "development", "testing"],
            "default": "production"
          },
          "last_updated": { "type": "string", "format": "date-time" },
          "optimization_candidate": { "type": "boolean", "default": false },
          "optimization_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["over_provisioned", "under_utilized", "missing_hpa", "inefficient_scaling", "resource_imbalance"]
            }
          }
        }
      }
    },

    "storage_volumes": {
      "description": "Persistent volume claims and storage utilization",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pvc_name", "namespace", "size"],
        "properties": {
          "pvc_name": { "type": "string" },
          "namespace": { "type": "string" },
          "storage_class": { "type": "string" },
          "size": {
            "type": "object",
            "properties": {
              "requested_gb": { "type": "number", "minimum": 0 },
              "used_gb": { "type": "number", "minimum": 0 },
              "utilization_percentage": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          },
          "monthly_cost": { "type": "number", "minimum": 0 },
          "performance_tier": {
            "type": "string",
            "enum": ["Standard_LRS", "Premium_LRS", "StandardSSD_LRS", "UltraSSD_LRS"]
          },
          "last_accessed": { "type": "string", "format": "date-time" },
          "attached_workload": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "namespace": { "type": "string" },
              "type": { "type": "string" }
            }
          },
          "backup_enabled": { "type": "boolean", "default": false },
          "snapshot_count": { "type": "integer", "minimum": 0 },
          "iops_usage": {
            "type": "object",
            "properties": {
              "avg_read_iops": { "type": "number", "minimum": 0 },
              "avg_write_iops": { "type": "number", "minimum": 0 },
              "peak_iops": { "type": "number", "minimum": 0 }
            }
          },
          "optimization_candidate": { "type": "boolean", "default": false },
          "optimization_reason": {
            "type": "string",
            "enum": ["oversized", "underutilized", "wrong_tier", "orphaned"]
          }
        }
      }
    },

    "existing_hpas": {
      "description": "Current HPA configurations and performance",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "namespace", "target_ref"],
        "properties": {
          "name": { "type": "string" },
          "namespace": { "type": "string" },
          "target_ref": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "name": { "type": "string" }
            }
          },
          "min_replicas": { "type": "integer", "minimum": 1 },
          "max_replicas": { "type": "integer", "minimum": 1 },
          "current_replicas": { "type": "integer", "minimum": 0 },
          "desired_replicas": { "type": "integer", "minimum": 0 },
          "target_metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { 
                  "type": "string", 
                  "enum": ["Resource", "Pods", "Object", "External"]
                },
                "resource": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string", "enum": ["cpu", "memory"] },
                    "target": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string", "enum": ["Utilization", "AverageValue"] },
                        "averageUtilization": { "type": "integer", "minimum": 1, "maximum": 100 },
                        "averageValue": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          },
          "current_metrics": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": { "type": "string" },
                "current_utilization": { "type": "number", "minimum": 0 },
                "target_utilization": { "type": "number", "minimum": 0 }
              }
            }
          },
          "scaling_events": {
            "type": "object",
            "properties": {
              "last_7d": { "type": "integer", "minimum": 0 },
              "last_24h": { "type": "integer", "minimum": 0 },
              "scale_up_events": { "type": "integer", "minimum": 0 },
              "scale_down_events": { "type": "integer", "minimum": 0 }
            }
          },
          "performance_metrics": {
            "type": "object",
            "properties": {
              "effectiveness_score": { "type": "number", "minimum": 0, "maximum": 10 },
              "avg_response_time_ms": { "type": "number", "minimum": 0 },
              "stability_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "cost_efficiency": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "last_scale_time": { "type": "string", "format": "date-time" },
          "status": {
            "type": "string",
            "enum": ["Active", "Inactive", "ScalingLimited", "Unknown"]
          }
        }
      }
    },

    "namespaces": {
      "description": "Namespace-level resource aggregation and cost allocation",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "labels": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "resource_usage": {
            "type": "object",
            "properties": {
              "pod_count": { "type": "integer", "minimum": 0 },
              "deployment_count": { "type": "integer", "minimum": 0 },
              "service_count": { "type": "integer", "minimum": 0 },
              "pvc_count": { "type": "integer", "minimum": 0 },
              "cpu_requests_total": { "type": "string" },
              "memory_requests_total": { "type": "string" },
              "cpu_limits_total": { "type": "string" },
              "memory_limits_total": { "type": "string" },
              "cpu_usage_avg": { "type": "number", "minimum": 0 },
              "memory_usage_avg": { "type": "number", "minimum": 0 }
            }
          },
          "monthly_cost_estimate": {
            "type": "object",
            "properties": {
              "total": { "type": "number", "minimum": 0 },
              "compute": { "type": "number", "minimum": 0 },
              "storage": { "type": "number", "minimum": 0 },
              "networking": { "type": "number", "minimum": 0 }
            }
          },
          "environment_type": {
            "type": "string",
            "enum": ["production", "staging", "development", "testing", "system"],
            "default": "production"
          },
          "team_owner": { "type": "string" },
          "cost_center": { "type": "string" },
          "optimization_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "inefficiencies": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["over_provisioned_pods", "unused_pvcs", "missing_resource_limits", "no_hpa_usage"]
            }
          }
        }
      }
    },

    "network_resources": {
      "description": "Network-related resources and their costs",
      "type": "object",
      "properties": {
        "public_ips": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "ip_address": { "type": "string" },
              "allocation_method": { "type": "string", "enum": ["Static", "Dynamic"] },
              "monthly_cost": { "type": "number", "minimum": 0 },
              "attached_to": { "type": "string" },
              "usage_gb_last_30d": { "type": "number", "minimum": 0 },
              "utilization": { "type": "string", "enum": ["high", "medium", "low", "unused"] }
            }
          }
        },
        "load_balancers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string", "enum": ["Standard", "Basic"] },
              "monthly_cost": { "type": "number", "minimum": 0 },
              "rule_count": { "type": "integer", "minimum": 0 },
              "backend_pool_count": { "type": "integer", "minimum": 0 },
              "data_processed_gb": { "type": "number", "minimum": 0 },
              "associated_services": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "ingress_resources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "namespace": { "type": "string" },
              "controller": { "type": "string" },
              "tls_enabled": { "type": "boolean" },
              "rule_count": { "type": "integer", "minimum": 0 },
              "monthly_requests": { "type": "number", "minimum": 0 },
              "avg_response_time_ms": { "type": "number", "minimum": 0 }
            }
          }
        },
        "total_network_cost": { "type": "number", "minimum": 0 },
        "egress_cost": { "type": "number", "minimum": 0 },
        "ingress_cost": { "type": "number", "minimum": 0 }
      }
    },

    "inefficient_workloads": {
      "description": "Pre-identified optimization candidates with specific inefficiencies",
      "type": "object",
      "properties": {
        "over_provisioned": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "workload": {
                "type": "object",
                "properties": {
                  "namespace": { "type": "string" },
                  "name": { "type": "string" },
                  "type": { "type": "string" }
                }
              },
              "inefficiency_details": {
                "type": "object",
                "properties": {
                  "cpu_waste_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                  "memory_waste_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                  "monthly_waste_cost": { "type": "number", "minimum": 0 },
                  "recommended_cpu": { "type": "string" },
                  "recommended_memory": { "type": "string" },
                  "potential_monthly_savings": { "type": "number", "minimum": 0 }
                }
              },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
              "priority": { "type": "string", "enum": ["high", "medium", "low"] }
            }
          }
        },
        "under_utilized": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "workload": {
                "type": "object",
                "properties": {
                  "namespace": { "type": "string" },
                  "name": { "type": "string" },
                  "type": { "type": "string" }
                }
              },
              "utilization_details": {
                "type": "object",
                "properties": {
                  "avg_cpu_utilization": { "type": "number", "minimum": 0, "maximum": 100 },
                  "avg_memory_utilization": { "type": "number", "minimum": 0, "maximum": 100 },
                  "replica_efficiency": { "type": "number", "minimum": 0, "maximum": 1 },
                  "idle_time_percentage": { "type": "number", "minimum": 0, "maximum": 100 },
                  "scaling_opportunity": { "type": "boolean" }
                }
              },
              "recommendations": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["reduce_replicas", "implement_hpa", "schedule_scaling", "consolidate_workload"]
                }
              }
            }
          }
        },
        "missing_hpa_candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "workload": {
                "type": "object",
                "properties": {
                  "namespace": { "type": "string" },
                  "name": { "type": "string" },
                  "type": { "type": "string" }
                }
              },
              "hpa_suitability": {
                "type": "object",
                "properties": {
                  "traffic_variability": { "type": "number", "minimum": 0, "maximum": 1 },
                  "scaling_potential": { "type": "number", "minimum": 0, "maximum": 1 },
                  "stateless_score": { "type": "number", "minimum": 0, "maximum": 1 },
                  "estimated_savings": { "type": "number", "minimum": 0 },
                  "recommended_hpa_config": {
                    "type": "object",
                    "properties": {
                      "min_replicas": { "type": "integer", "minimum": 1 },
                      "max_replicas": { "type": "integer", "minimum": 1 },
                      "target_cpu": { "type": "integer", "minimum": 1, "maximum": 100 },
                      "target_memory": { "type": "integer", "minimum": 1, "maximum": 100 }
                    }
                  }
                }
              }
            }
          }
        },
        "orphaned_resources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "resource_type": { 
                "type": "string", 
                "enum": ["PVC", "ConfigMap", "Secret", "Service", "PublicIP", "LoadBalancer"]
              },
              "name": { "type": "string" },
              "namespace": { "type": "string" },
              "last_used": { "type": "string", "format": "date-time" },
              "monthly_cost": { "type": "number", "minimum": 0 },
              "safe_to_delete": { "type": "boolean" },
              "dependencies": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total_optimization_opportunities": { "type": "integer", "minimum": 0 },
            "total_potential_monthly_savings": { "type": "number", "minimum": 0 },
            "high_priority_count": { "type": "integer", "minimum": 0 },
            "medium_priority_count": { "type": "integer", "minimum": 0 },
            "low_priority_count": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "metadata": {
      "description": "Analysis metadata and configuration",
      "type": "object",
      "properties": {
        "schema_version": { "type": "string", "default": "2.0.0" },
        "collection_timestamp": { "type": "string", "format": "date-time" },
        "analysis_scope": {
          "type": "object",
          "properties": {
            "include_system_namespaces": { "type": "boolean", "default": false },
            "cost_analysis_period_days": { "type": "integer", "minimum": 1, "default": 30 },
            "metrics_lookback_days": { "type": "integer", "minimum": 1, "default": 7 }
          }
        },
        "data_sources": {
          "type": "object",
          "properties": {
            "azure_cost_management": { "type": "boolean" },
            "prometheus_metrics": { "type": "boolean" },
            "kubernetes_api": { "type": "boolean" },
            "azure_monitor": { "type": "boolean" }
          }
        },
        "collection_confidence": {
          "type": "object",
          "properties": {
            "overall_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "cost_data_quality": { "type": "number", "minimum": 0, "maximum": 1 },
            "metrics_completeness": { "type": "number", "minimum": 0, "maximum": 1 },
            "workload_coverage": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    }
  },
  
  "examples": [
    {
