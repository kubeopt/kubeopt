{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "KubeOpt Implementation Plan Schema",
  "description": "Comprehensive implementation plan for AKS cost optimization with detailed analysis and actionable steps",
  "properties": {
    "implementation_plan": {
      "type": "object",
      "title": "KubeOptImplementationPlan",
      "description": "Complete KubeOpt Implementation Plan",
      "properties": {
        "metadata": {
          "type": "object",
          "title": "PlanMetadata",
          "description": "Implementation plan metadata",
          "properties": {
            "plan_id": {
              "type": "string",
              "description": "Unique plan identifier"
            },
            "cluster_name": {
              "type": "string",
              "description": "AKS cluster name"
            },
            "generated_date": {
              "type": "string",
              "format": "date-time",
              "description": "Plan generation timestamp"
            },
            "analysis_date": {
              "type": "string",
              "format": "date-time",
              "description": "Original analysis timestamp"
            },
            "last_analyzed_display": {
              "type": "string",
              "description": "Human-readable analysis age"
            }
          },
          "required": ["plan_id", "cluster_name", "generated_date", "analysis_date", "last_analyzed_display"]
        },
        "cluster_dna_analysis": {
          "type": "object",
          "title": "ClusterDNAAnalysis",
          "description": "Cluster DNA quality analysis",
          "properties": {
            "overall_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Overall cluster quality score"
            },
            "score_rating": {
              "type": "string",
              "description": "Overall rating"
            },
            "description": {
              "type": "string",
              "description": "Detailed assessment description"
            },
            "metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "DNAMetric",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Metric name"
                  },
                  "value": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Metric score (0-100)"
                  },
                  "percentage": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100,
                    "description": "Percentage representation"
                  },
                  "rating": {
                    "type": "string",
                    "description": "Qualitative rating"
                  },
                  "color": {
                    "type": "string",
                    "enum": ["excellent", "good", "fair", "poor", "green", "blue", "purple", "red"],
                    "description": "Color coding for UI"
                  }
                },
                "required": ["label", "value", "percentage", "rating", "color"]
              },
              "description": "Individual metric scores"
            },
            "data_sources": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "DataSource",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Data source name"
                  },
                  "available": {
                    "type": "boolean",
                    "description": "Whether source is available"
                  }
                },
                "required": ["name", "available"]
              },
              "description": "Available data sources"
            }
          },
          "required": ["overall_score", "score_rating", "description", "metrics", "data_sources"]
        },
        "build_quality_assessment": {
          "type": "object",
          "title": "BuildQualityAssessment",
          "description": "Build quality and best practices assessment",
          "properties": {
            "quality_checks": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "QualityCheck",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Check name"
                  },
                  "status": {
                    "type": "string",
                    "description": "Check result"
                  },
                  "status_type": {
                    "type": "string",
                    "enum": ["good", "warning", "error", "info"],
                    "description": "Status classification"
                  }
                },
                "required": ["label", "status", "status_type"]
              },
              "description": "Quality check results"
            },
            "strengths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Identified strengths"
            },
            "improvements": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Areas for improvement"
            },
            "best_practices_scorecard": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "BestPracticeScore",
                "properties": {
                  "category": {
                    "type": "string",
                    "description": "Practice category"
                  },
                  "score": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Current score"
                  },
                  "max_score": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Maximum possible score"
                  },
                  "color": {
                    "type": "string",
                    "enum": ["excellent", "good", "fair", "poor", "green", "blue", "purple", "red"],
                    "description": "Color coding"
                  }
                },
                "required": ["category", "score", "max_score", "color"]
              },
              "description": "Best practice scores"
            }
          },
          "required": ["quality_checks", "strengths", "improvements", "best_practices_scorecard"]
        },
        "naming_conventions_analysis": {
          "type": "object",
          "title": "NamingConventionsAnalysis",
          "description": "Naming conventions analysis",
          "properties": {
            "overall_score": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100,
              "description": "Overall naming score"
            },
            "max_score": {
              "type": "integer",
              "minimum": 0,
              "description": "Maximum possible score"
            },
            "color": {
              "type": "string",
              "enum": ["excellent", "good", "fair", "poor", "green", "blue", "purple", "red"],
              "description": "Color coding"
            },
            "resources": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "NamingConventionResource",
                "properties": {
                  "resource_type": {
                    "type": "string",
                    "description": "Type of resource"
                  },
                  "example": {
                    "type": "string",
                    "description": "Example resource name"
                  },
                  "pattern": {
                    "type": "string",
                    "description": "Identified naming pattern"
                  },
                  "compliance": {
                    "type": "string",
                    "enum": ["EXCELLENT", "GOOD", "INCONSISTENT", "NEEDS IMPROVEMENT"],
                    "description": "Compliance level"
                  },
                  "badge_type": {
                    "type": "string",
                    "enum": ["success", "warning", "danger", "info"],
                    "description": "UI badge type"
                  }
                },
                "required": ["resource_type", "example", "pattern", "compliance", "badge_type"]
              },
              "description": "Per-resource analysis"
            },
            "strengths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Naming strengths"
            },
            "recommendations": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Naming recommendations"
            }
          },
          "required": ["overall_score", "max_score", "color", "resources", "strengths", "recommendations"]
        },
        "roi_analysis": {
          "type": "object",
          "title": "ROIAnalysis",
          "description": "Complete ROI and financial analysis",
          "properties": {
            "summary_metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "ROISummaryMetric",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Metric label"
                  },
                  "value": {
                    "type": "string",
                    "description": "Formatted value"
                  },
                  "subtitle": {
                    "type": "string",
                    "description": "Additional context"
                  },
                  "color": {
                    "type": "string",
                    "enum": ["excellent", "good", "fair", "poor", "green", "blue", "purple", "red"],
                    "description": "Color coding"
                  }
                },
                "required": ["label", "value", "subtitle", "color"]
              },
              "description": "Key ROI metrics"
            },
            "calculation_breakdown": {
              "type": "object",
              "title": "ROICalculationBreakdown",
              "properties": {
                "total_effort_hours": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Total implementation hours"
                },
                "hourly_rate": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Hourly implementation rate"
                },
                "implementation_cost": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Total implementation cost"
                },
                "monthly_savings": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Monthly cost savings"
                },
                "annual_savings": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Annual cost savings"
                },
                "payback_months": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Months to break even"
                },
                "roi_percentage_year1": {
                  "type": "number",
                  "description": "Year 1 ROI percentage"
                },
                "net_savings_year1": {
                  "type": "number",
                  "description": "Net savings after year 1"
                },
                "projected_savings_3year": {
                  "type": "number",
                  "description": "3-year projected savings"
                }
              },
              "required": ["total_effort_hours", "hourly_rate", "implementation_cost", "monthly_savings", "annual_savings", "payback_months", "roi_percentage_year1", "net_savings_year1", "projected_savings_3year"],
              "description": "Detailed calculations"
            },
            "financial_summary": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Financial summary statements"
            },
            "savings_by_phase": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "PhaseROI",
                "properties": {
                  "phase": {
                    "type": "string",
                    "description": "Phase name"
                  },
                  "duration": {
                    "type": "string",
                    "description": "Phase duration"
                  },
                  "effort_hours": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Phase effort in hours"
                  },
                  "monthly_savings": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Monthly savings from phase"
                  },
                  "annual_savings": {
                    "type": "number",
                    "minimum": 0,
                    "description": "Annual savings from phase"
                  }
                },
                "required": ["phase", "duration", "effort_hours", "monthly_savings", "annual_savings"]
              },
              "description": "Phase-by-phase ROI"
            }
          },
          "required": ["summary_metrics", "calculation_breakdown", "financial_summary", "savings_by_phase"]
        },
        "implementation_summary": {
          "type": "object",
          "title": "ImplementationSummary",
          "description": "High-level implementation summary",
          "properties": {
            "cluster_name": {
              "type": "string",
              "description": "Target cluster name"
            },
            "environment": {
              "type": "string",
              "description": "Environment (Dev/UAT/Prod)"
            },
            "location": {
              "type": "string",
              "description": "Azure region"
            },
            "kubernetes_version": {
              "type": "string",
              "description": "K8s version"
            },
            "current_monthly_cost": {
              "type": "number",
              "minimum": 0,
              "description": "Current monthly cost"
            },
            "projected_monthly_cost": {
              "type": "number",
              "minimum": 0,
              "description": "Projected monthly cost"
            },
            "cost_reduction_percentage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "Cost reduction %"
            },
            "implementation_duration": {
              "type": "string",
              "description": "Total implementation time"
            },
            "total_phases": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of implementation phases"
            },
            "risk_level": {
              "type": "string",
              "enum": ["Very Low", "Low", "Medium", "High", "Critical"],
              "description": "Overall risk assessment"
            }
          },
          "required": ["cluster_name", "environment", "location", "kubernetes_version", "current_monthly_cost", "projected_monthly_cost", "cost_reduction_percentage", "implementation_duration", "total_phases", "risk_level"]
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "ImplementationPhase",
            "description": "Implementation phase with grouped actions",
            "properties": {
              "phase_number": {
                "type": "integer",
                "minimum": 1,
                "description": "Phase sequence number"
              },
              "phase_name": {
                "type": "string",
                "description": "Phase name"
              },
              "description": {
                "type": "string",
                "description": "Phase description"
              },
              "duration": {
                "type": "string",
                "description": "Phase duration"
              },
              "start_date": {
                "type": "string",
                "format": "date",
                "description": "Phase start date"
              },
              "end_date": {
                "type": "string",
                "format": "date",
                "description": "Phase end date"
              },
              "total_savings_monthly": {
                "type": "number",
                "minimum": 0,
                "description": "Total monthly savings"
              },
              "risk_level": {
                "type": "string",
                "enum": ["Very Low", "Low", "Medium", "High", "Critical"],
                "description": "Phase risk level"
              },
              "effort_hours": {
                "type": "number",
                "minimum": 0,
                "description": "Total phase effort"
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "title": "OptimizationAction",
                  "description": "Individual optimization action within a phase",
                  "properties": {
                    "action_id": {
                      "type": "string",
                      "description": "Unique action identifier"
                    },
                    "title": {
                      "type": "string",
                      "description": "Action title"
                    },
                    "description": {
                      "type": "string",
                      "description": "Detailed description"
                    },
                    "savings_monthly": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Monthly savings from action"
                    },
                    "risk": {
                      "type": "string",
                      "enum": ["Very Low", "Low", "Medium", "High", "Critical"],
                      "description": "Risk level"
                    },
                    "effort_hours": {
                      "type": "number",
                      "minimum": 0,
                      "description": "Implementation effort"
                    },
                    "issue_type": {
                      "type": "string",
                      "enum": ["good", "warning", "error", "info"],
                      "description": "Issue classification"
                    },
                    "issue_text": {
                      "type": "string",
                      "description": "Current issue description"
                    },
                    "steps": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "ActionStep",
                        "properties": {
                          "step_number": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "Step sequence number"
                          },
                          "label": {
                            "type": "string",
                            "description": "Step description"
                          },
                          "command": {
                            "type": "string",
                            "description": "Command to execute"
                          },
                          "expected_output": {
                            "type": ["string", "null"],
                            "description": "Expected command output"
                          }
                        },
                        "required": ["step_number", "label", "command"]
                      },
                      "description": "Implementation steps"
                    },
                    "notes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "title": "ActionNote",
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": ["note", "warning", "info", "error"],
                            "description": "Note type"
                          },
                          "text": {
                            "type": "string",
                            "description": "Note content"
                          }
                        },
                        "required": ["type", "text"]
                      },
                      "description": "Additional notes"
                    },
                    "success_criteria": {
                      "type": ["array", "null"],
                      "items": {
                        "type": "string"
                      },
                      "description": "Success criteria"
                    },
                    "rollback": {
                      "type": ["object", "null"],
                      "title": "ActionRollback",
                      "properties": {
                        "command": {
                          "type": "string",
                          "description": "Rollback command"
                        },
                        "description": {
                          "type": "string",
                          "description": "Rollback description"
                        }
                      },
                      "required": ["command", "description"],
                      "description": "Rollback instructions"
                    }
                  },
                  "required": ["action_id", "title", "description", "savings_monthly", "risk", "effort_hours", "issue_type", "issue_text", "steps"]
                },
                "description": "Phase actions"
              }
            },
            "required": ["phase_number", "phase_name", "description", "duration", "start_date", "end_date", "total_savings_monthly", "risk_level", "effort_hours", "actions"]
          },
          "description": "Implementation phases"
        },
        "monitoring": {
          "type": "object",
          "title": "MonitoringGuidance",
          "description": "Post-implementation monitoring guidance",
          "properties": {
            "title": {
              "type": "string",
              "description": "Monitoring section title"
            },
            "description": {
              "type": "string",
              "description": "Monitoring description"
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "MonitoringCommand",
                "properties": {
                  "label": {
                    "type": "string",
                    "description": "Command description"
                  },
                  "command": {
                    "type": "string",
                    "description": "Command to execute"
                  }
                },
                "required": ["label", "command"]
              },
              "description": "Monitoring commands"
            },
            "key_metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "title": "MonitoringMetric",
                "properties": {
                  "metric": {
                    "type": "string",
                    "description": "Metric name"
                  },
                  "target": {
                    "type": "string",
                    "description": "Target value and alert conditions"
                  }
                },
                "required": ["metric", "target"]
              },
              "description": "Key metrics to track"
            }
          },
          "required": ["title", "description", "commands", "key_metrics"]
        },
        "review_schedule": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "ReviewScheduleItem",
            "properties": {
              "day": {
                "type": "integer",
                "minimum": 1,
                "description": "Day number for review"
              },
              "title": {
                "type": "string",
                "description": "Review checkpoint description"
              }
            },
            "required": ["day", "title"]
          },
          "description": "Review schedule"
        }
      },
      "required": [
        "metadata",
        "cluster_dna_analysis", 
        "build_quality_assessment",
        "naming_conventions_analysis",
        "roi_analysis",
        "implementation_summary",
        "phases",
        "monitoring",
        "review_schedule"
      ]
    }
  },
  "required": ["implementation_plan"]
}